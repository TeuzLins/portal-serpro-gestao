# ──────────────────────────────────────────────
#  Portal SERPRO – Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://serpro:SENHA_AQUI@localhost:5432/serpro
# Ou separe por variáveis individuais (opcional):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=serpro
# DB_USER=serpro
# DB_PASSWORD=SENHA_AQUI

# JWT
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio_em_producao
JWT_EXPIRES_IN=8h

# CORS – origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost,http://localhost:80

# Rate limit (requisições por janela de 15 min por IP)
RATE_LIMIT_MAX=300
